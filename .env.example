# ==========================================================
# Quix AI Portfolio Assistant — Environment Variables
# ==========================================================
# This project is fully local — no API key is required.
#
# Embeddings: BAAI/bge-small-en-v1.5 via @xenova/transformers (local, offline).
# Answer generation: a local LLM served by Ollama (https://ollama.com).
#
# Setup:
#   1. Install Ollama:      https://ollama.com/download
#   2. Pull a chat model:   ollama pull llama3.1
#   3. Ollama serves itself automatically on http://localhost:11434
#
# If Ollama isn't running, the assistant will still boot and reply with
# "AI service is temporarily unavailable." instead of crashing.

# Base URL of your local Ollama server. Default is fine for local dev.
OLLAMA_HOST=http://localhost:11434

# Which locally-pulled model to use for chat generation.
# Other good options: qwen2.5, mistral, phi3, gemma2 — pull with
# `ollama pull <model>` first.
OLLAMA_MODEL=llama3.1

# Timezone used for the "Are you available now?" business-hours logic.
ASSISTANT_TIMEZONE=Asia/Kolkata
